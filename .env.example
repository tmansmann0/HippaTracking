PORT=3000
PUBLIC_BASE_URL=https://your-relay.up.railway.app
APP_SECRET=change-me-to-a-long-random-secret
APP_ENCRYPTION_KEY=change-me-to-a-32-byte-random-secret
DATABASE_URL=

# Comma-separated origins allowed to load /pixel.js and POST /collect.
# Use exact origins, for example: https://example.com,https://www.example.com
ALLOWED_ORIGINS=https://example.com

# Public site identifier used by the pixel snippet.
RELAY_SITE_ID=default

# strict = forward the absolute minimum; attribution = forward fbp/fbc when consent is granted and route is not sensitive.
PRIVACY_MODE=strict

# Comma-separated terms or route fragments that mark a page as sensitive.
SENSITIVE_PATH_PATTERNS=botox,filler,laser,body-contouring,coolsculpting,semaglutide,glp-1,weight-loss,hormone,iv-therapy,consultation

# Optional comma-separated event custom_data keys allowed to pass downstream.
ALLOWED_CUSTOM_DATA_KEYS=value,currency

# Meta Conversions API
META_ENABLED=false
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v21.0
META_TEST_EVENT_CODE=

# GA4 Measurement Protocol
GA4_ENABLED=false
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
GA4_ENDPOINT_REGION=global

# Optional sanitized event log. On Railway, attach a volume before using a persistent path.
EVENT_LOG_PATH=
